# Frontend-only mode. VITE_MOCK enables the in-browser mock backend; no real
# services are used (Sentry/PostHog/FullStory/Pusher/Petavue API are all gated
# off in mock mode). Set VITE_MOCK=false only if wiring a real backend.
VITE_MOCK=true

# Dummy id so the Google OAuth provider mounts without warnings (login is mocked).
VITE_GOOGLE_CLIENT_ID=mock-client-id
